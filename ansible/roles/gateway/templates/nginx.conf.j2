# /etc/nginx/sites-available/inference-api.conf
# Managed by Ansible – do not edit manually

# Rate limiting zone – protects inference worker from being hammered
limit_req_zone $binary_remote_addr zone=inference_limit:10m rate=10r/s;

server {
    listen 80;
    server_name _;

    # Security headers
    add_header X-Frame-Options           "DENY"            always;
    add_header X-Content-Type-Options    "nosniff"         always;
    add_header X-XSS-Protection          "1; mode=block"   always;
    add_header Referrer-Policy           "no-referrer"     always;
    add_header Content-Security-Policy   "default-src 'none'" always;

    # Hide nginx version
    server_tokens off;

    # Health check endpoint (doesn't hit the engine)
    location /health {
        access_log off;
        return 200 '{"status":"ok","service":"alchemyst-inference-gateway"}';
        add_header Content-Type application/json;
    }

    # Main inference API – proxy to iii engine REST port
    location /v1/ {
        limit_req zone=inference_limit burst=20 nodelay;

        proxy_pass         http://{{ engine_ip }}:{{ iii_engine_rest_port }};
        proxy_http_version 1.1;

        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Timeouts – inference can take a few seconds
        proxy_connect_timeout  10s;
        proxy_send_timeout     120s;
        proxy_read_timeout     120s;

        # Buffer settings for streaming-ready responses
        proxy_buffering    off;
        proxy_buffer_size  4k;
    }

    # Block everything else
    location / {
        return 404 '{"error":"not found"}';
        add_header Content-Type application/json;
    }
}
